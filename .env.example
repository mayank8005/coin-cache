# ---- Core ----
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
APP_URL=http://localhost:3000

# ---- Database ----
# SQLite file path (Docker volume maps /app/data). In dev, defaults to ./prisma/dev.db.
DATABASE_URL="file:./prisma/dev.db"

# ---- Auth ----
# Generate a long random string (openssl rand -base64 48)
AUTH_SECRET=change-me-to-a-long-random-string
# Session cookie lifetime in seconds (default 7 days)
AUTH_SESSION_MAX_AGE=604800

# ---- Admin CLI gate ----
# bcrypt hash of the master password. Generate once:
#   node -e 'require("bcryptjs").hash(process.argv[1], 12).then(console.log)' 'my-master-pass'
ADMIN_PASSWORD_HASH=

# Plaintext master password used BY the admin CLI to authenticate to /api/admin.
# Keep this out of any shared env; populate on the operator machine only.
ADMIN_PASSWORD=

# ---- Field encryption ----
# 32+ char random key. Used to derive per-user keys (HKDF) for AES-256-GCM.
ENCRYPTION_KEY=change-me-32-plus-random-chars-xxxxxxxx

# ---- Legacy server LLM (optional) ----
# UI AI calls are made from the browser using per-user Settings.
# These are only for legacy server-side AI routes.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_HEALTH_TIMEOUT_MS=1500
